<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tacogram</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="pt-4">
  <div class="container">
    <div class="row justify-content-end mb-2">
      <div class="col">
        <%= flash[:notice] || flash[:alert] %>
      </div>
      <div class="col-3 text-end">
        <% if logged_in? %>
          <span class="me-2">Hello, <%= current_user.first_name %></span>
          <a href="/logout" class="btn btn-default">Logout</a>
        <% else %>
          <a href="/login" class="btn btn-default">Login</a> |
          <a href="/users/new" class="btn btn-default">Signup</a>
        <% end %>
      </div>
    </div>

    <div class="row">
      <div class="col">
        <h1 class="display-6 mb-4">Tacostagram</h1>
      </div>
      <div class="col-2 text-end">
        <% if logged_in? %>
          <a href="/posts/new/" class="btn btn-success">New Post</a>
        <% end %>
      </div>
    </div>

    <%= yield %>
  </div>
</body>
</html>